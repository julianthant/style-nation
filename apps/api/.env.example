# Environment
NODE_ENV="development"
PORT=3001

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/car_showroom"
DIRECT_URL="postgresql://postgres:password@localhost:5432/car_showroom"

# Supabase
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_KEY="your-service-key"
SUPABASE_JWT_SECRET="your-jwt-secret"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_SECRET="your-refresh-token-secret-minimum-32-characters"
REFRESH_TOKEN_EXPIRES_IN="30d"

# Facebook Integration
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"
FACEBOOK_PAGE_ID="your-facebook-page-id"
FACEBOOK_PAGE_ACCESS_TOKEN="your-facebook-page-access-token"
FACEBOOK_WEBHOOK_VERIFY_TOKEN="your-webhook-verify-token"

# Storage
STORAGE_BUCKET="car-images"
MAX_FILE_SIZE=10485760

# Email (Postmark)
POSTMARK_API_KEY="your-postmark-api-key"
FROM_EMAIL="noreply@cardealership.com"

# Monitoring
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project"

# CORS
CORS_ORIGIN="http://localhost:3000"

# reCAPTCHA
RECAPTCHA_SECRET_KEY="your-recaptcha-secret-key"